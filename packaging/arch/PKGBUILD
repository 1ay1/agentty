# Maintainer: moha contributors <https://github.com/1ay1/moha>
#
# moha-bin — Arch package built from the upstream Linux x86_64 release
# tarball. No local compilation; just stages the pre-built binary +
# README into the right Arch layout (/usr/bin, /usr/share/doc/moha).
#
# CI flow (.github/workflows/release.yml → package-arch job):
#   1. linux-x86_64 build job runs first, uploads the tarball as an
#      artifact named "moha-linux-x86_64".
#   2. package-arch job pulls that artifact, drops it into $startdir
#      so makepkg's source-array dedup finds it locally and skips the
#      remote fetch, then runs `makepkg --skipchecksums` to produce
#      moha-bin-<ver>-1-x86_64.pkg.tar.zst.
#
# End-user flow (after a release is published):
#   1. Grab this PKGBUILD (or install from AUR once submitted).
#   2. `makepkg -si` — fetches the upstream tarball from the release
#      page, verifies the sha256 (CI bumps that for every release),
#      installs as `moha-bin`. Provides/conflicts with `moha`.

pkgname=moha-bin
_upstream=moha
pkgver=0.1.0
pkgrel=1
pkgdesc="A native terminal client for Claude — written in modern C++26"
arch=('x86_64')
url="https://github.com/1ay1/moha"
license=('MIT')
provides=('moha')
conflicts=('moha')
# moha is statically linked except libc + (usually) OpenSSL on Linux —
# anything not folded in shows up here. Auto-detection on the makepkg
# host (CI runs `namcap` style scans against the binary) refines this.
depends=('glibc' 'openssl' 'libnghttp2')

# Disable the debug-split package. makepkg's default OPTIONS=(debug
# strip) splits stripped symbols into a separate moha-bin-debug
# .pkg.tar.zst — pointless for a binary repackage where the upstream
# tarball is already a Release build with no debug info to extract.
# !strip preserves any symbols that *are* in the binary; !lto suppresses
# makepkg's auto-LTO injection (would error on a precompiled binary).
options=('!debug' '!strip' '!lto')

source=("https://github.com/1ay1/moha/releases/download/v${pkgver}/${_upstream}-${pkgver}-linux-x86_64.tar.gz")
# CI invokes makepkg with `--skipchecksums` because the package is built
# in the same workflow run that produces the upstream tarball — the
# checksum doesn't exist yet at PKGBUILD time. End users running
# `makepkg -si` after a release should hand-update this hash from the
# release's SHA256SUMS file (or the AUR submission can pin it once).
sha256sums=('SKIP')

package() {
    cd "$srcdir/${_upstream}-${pkgver}-linux-x86_64"

    install -Dm755 moha             "$pkgdir/usr/bin/moha"
    install -Dm644 README.md        "$pkgdir/usr/share/doc/moha/README.md"
    if [ -f LICENSE ]; then
        install -Dm644 LICENSE      "$pkgdir/usr/share/licenses/moha/LICENSE"
    fi
}
